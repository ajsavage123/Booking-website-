# ============================================================
# MediCare Clinic — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# Get these from: https://supabase.com → Your Project → Settings → API

# Project URL (public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon/Public Key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key (SECRET — server only, never expose to browser!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Admin ─────────────────────────────────────────────────────
# Password for the admin dashboard login
# Change this to a strong password before deploying!
ADMIN_PASSWORD=admin123

# ── Clinic Config ─────────────────────────────────────────────
# WhatsApp number with country code (no + or spaces)
# e.g. Malaysia: 601234567890  |  US: 12125551234
NEXT_PUBLIC_CLINIC_WHATSAPP=601234567890

# Clinic name (optional — defaults to "MediCare Clinic")
NEXT_PUBLIC_CLINIC_NAME=MediCare Clinic
